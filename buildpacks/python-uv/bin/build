#!/usr/bin/env bash
set -eo pipefail

echo "---> Luban Python uv Buildpack"

# CNB_LAYERS_DIR, CNB_PLATFORM_DIR, CNB_BP_PLAN_PATH are provided by the lifecycle
# CNB_BUILDPACK_DIR is the root of the buildpack

# 1. Install uv
uv_layer="$CNB_LAYERS_DIR/uv"
mkdir -p "$uv_layer/bin"

binding_root="${SERVICE_BINDING_ROOT:-${CNB_PLATFORM_DIR:-/platform}/bindings}"
NETRC_FILE=""
if [ -d "$binding_root" ]; then
    for d in "$binding_root"/*; do
        [ -d "$d" ] || continue
        if [ -f "$d/type" ] && [ "$(cat "$d/type" 2>/dev/null || true)" = "netrc" ] && [ -f "$d/netrc" ]; then
            NETRC_FILE="/tmp/uv-mirror.netrc"
            cp "$d/netrc" "$NETRC_FILE"
            chmod 600 "$NETRC_FILE"
            export NETRC="$NETRC_FILE"
            break
        fi
    done
fi

download() {
    local url out
    url="$1"
    out="$2"

    WGET_ARGS=()
    if [ -n "$NETRC_FILE" ]; then
        HOME="${HOME:-/tmp}"
        mkdir -p "$HOME"
        cp "$NETRC_FILE" "$HOME/.netrc"
        chmod 600 "$HOME/.netrc"
        WGET_ARGS+=(--netrc)
    fi

    wget -q -O "$out" "${WGET_ARGS[@]}" "$url"
}

# Determine uv version
DEFAULT_UV_VERSION="0.10.4"

# Try to read default version from buildpack.toml
if [[ -f "$CNB_BUILDPACK_DIR/buildpack.toml" ]]; then
    # Simple grep fallback because we don't have python yet
    TOML_VERSION=$(grep 'uv = "' "$CNB_BUILDPACK_DIR/buildpack.toml" | cut -d'"' -f2)
    if [[ -n "$TOML_VERSION" ]]; then
        DEFAULT_UV_VERSION="$TOML_VERSION"
    fi
fi

UV_VERSION="$DEFAULT_UV_VERSION"

if [[ -f ".uv-version" ]]; then
    UV_VERSION=$(cat .uv-version | tr -d '[:space:]')
    echo "User requested uv version: $UV_VERSION"
else
    echo "Using default uv version: $UV_VERSION"
fi

# Check cached version
CACHED_VERSION=""
if [[ -f "$uv_layer/version" ]]; then
    CACHED_VERSION=$(cat "$uv_layer/version")
fi

# Check if uv is cached and version matches, if not download
if [[ "$CACHED_VERSION" != "$UV_VERSION" ]] || [[ ! -f "$uv_layer/bin/uv" ]]; then
    echo "Installing uv $UV_VERSION..."
    ARCH=$(uname -m)

    UV_RELEASE_BASE_URL=${BP_UV_RELEASE_BASE_URL:-"https://github.com/astral-sh/uv/releases/download"}
    UV_RELEASE_BASE_URL=${UV_RELEASE_BASE_URL%/}

    if [[ "$ARCH" == "x86_64" ]]; then
        UV_URL="${UV_RELEASE_BASE_URL}/${UV_VERSION}/uv-x86_64-unknown-linux-musl.tar.gz"
    elif [[ "$ARCH" == "aarch64" ]]; then
        UV_URL="${UV_RELEASE_BASE_URL}/${UV_VERSION}/uv-aarch64-unknown-linux-musl.tar.gz"
    else
        echo "Unsupported architecture: $ARCH"
        exit 1
    fi
    
    # Download
    echo "Downloading uv from $UV_URL..."
    download "$UV_URL" uv.tar.gz || { echo "Error: Failed to download uv from $UV_URL"; exit 1; }

    # Verify Checksum
    echo "Verifying checksum..."
    CHECKSUM_URL="${UV_URL}.sha256"
    download "$CHECKSUM_URL" uv.tar.gz.sha256 || { echo "Error: Failed to download checksum from $CHECKSUM_URL"; exit 1; }
    
    EXPECTED_SHA256=$(cat uv.tar.gz.sha256 | cut -d' ' -f1)
    ACTUAL_SHA256=$(sha256sum uv.tar.gz | cut -d' ' -f1)
    
    if [[ "$ACTUAL_SHA256" != "$EXPECTED_SHA256" ]]; then
        echo "Error: Checksum mismatch!"
        echo "Expected: $EXPECTED_SHA256"
        echo "Actual:   $ACTUAL_SHA256"
        exit 1
    fi
    echo "Checksum verified."

    # Extract
    tar -xzf uv.tar.gz -C "$uv_layer/bin" --strip-components=1
    rm uv.tar.gz uv.tar.gz.sha256
    
    # Save version for caching
    echo "$UV_VERSION" > "$uv_layer/version"
    echo "uv installed."
else
    echo "Using cached uv $UV_VERSION"
fi

# Write layer metadata for uv
cat <<EOF > "$uv_layer.toml"
[types]
cache = true
build = true
launch = true
EOF

export PATH="$uv_layer/bin:$PATH"

# 2. Configure uv paths
python_layer="$CNB_LAYERS_DIR/python"
mkdir -p "$python_layer"
export UV_PYTHON_INSTALL_DIR="$python_layer"

cat <<EOF > "$python_layer.toml"
[types]
cache = true
build = true
launch = true
EOF

uv_cache_layer="$CNB_LAYERS_DIR/uv_cache"
export UV_CACHE_DIR="$uv_cache_layer"

cat <<EOF > "$uv_cache_layer.toml"
[types]
cache = true
build = true
EOF

# 3. Setup Virtual Environment Layer (Cached)
venv_layer="$CNB_LAYERS_DIR/venv"
mkdir -p "$venv_layer"
rm -rf .venv
ln -s "$venv_layer" .venv

cat <<EOF > "$venv_layer.toml"
[types]
cache = true
build = true
launch = true
EOF

# 4. Install Python and Dependencies
echo "Installing dependencies with uv..."

if [[ -n "${BP_UV_PYTHON_INSTALL_MIRROR:-}" ]]; then
    export UV_PYTHON_INSTALL_MIRROR="$BP_UV_PYTHON_INSTALL_MIRROR"
fi

if [[ -f "uv.lock" ]]; then
    uv sync --frozen --no-dev
else
    uv sync --no-dev
fi

echo "Pruning uv cache..."
uv cache prune

# 5. Generate dbt manifest.json (if dbt project exists)
BP_DBT_PROJECT_DIR="${BP_DBT_PROJECT_DIR:-dbt_project}"
if [[ -d "$BP_DBT_PROJECT_DIR" ]] && [[ -f "$BP_DBT_PROJECT_DIR/dbt_project.yml" ]]; then
    echo "Detected dbt project at $BP_DBT_PROJECT_DIR, generating manifest.json..."
    BP_DBT_PROFILES_DIR="${BP_DBT_PROFILES_DIR:-$BP_DBT_PROJECT_DIR}"
    BP_DBT_TARGET="${BP_DBT_TARGET:-sandbox}"
    export DBT_PROFILES_DIR="$BP_DBT_PROFILES_DIR"
    export DBT_TARGET="$BP_DBT_TARGET"
    if [[ -f "$BP_DBT_PROJECT_DIR/packages.yml" ]] || grep -q "packages:" "$BP_DBT_PROJECT_DIR/dbt_project.yml"; then
        echo "Running dbt deps..."
        uv run dbt deps --project-dir "$BP_DBT_PROJECT_DIR" || { echo "Error: dbt deps failed"; exit 1; }
    fi
    echo "Running dbt parse..."
    uv run dbt parse --project-dir "$BP_DBT_PROJECT_DIR" || { echo "Error: dbt parse failed"; exit 1; }
    if [[ ! -f "$BP_DBT_PROJECT_DIR/target/manifest.json" ]]; then
        echo "Error: manifest.json was not created at $BP_DBT_PROJECT_DIR/target/manifest.json"
        exit 1
    fi
    echo "dbt manifest.json generated."
else
    echo "No dbt project detected at $BP_DBT_PROJECT_DIR, skipping dbt manifest generation."
fi

# 6. Set launch configuration
echo "Configuring launch..."

# Use extracted python script to parse pyproject.toml
PYTHON_BIN=".venv/bin/python"
PARSE_SCRIPT="$CNB_BUILDPACK_DIR/bin/parse_config.py"

if [[ -f "$PYTHON_BIN" ]] && [[ -f "$PARSE_SCRIPT" ]]; then
    # Run the parsing script and eval its output
    PARSED_OUTPUT=$($PYTHON_BIN "$PARSE_SCRIPT")
    if [[ $? -eq 0 ]]; then
        eval "$PARSED_OUTPUT"
    else
        echo "Warning: Failed to parse pyproject.toml. Falling back to defaults."
        BP_EXECUTION_MODE="standard"
        SCRIPT_NAME=""
    fi
else
    echo "Warning: Python or parse script not found. Using defaults."
    BP_EXECUTION_MODE="standard"
    SCRIPT_NAME=""
fi

# Set defaults if empty
BP_EXECUTION_MODE=${MODE:-"standard"}
SCRIPT_NAME=${SCRIPT_NAME:-""}

echo "Detected bp-execution-mode: $BP_EXECUTION_MODE"
if [[ -n "$SCRIPT_NAME" ]]; then
    echo "Found entry point script: $SCRIPT_NAME"
fi

# Generate launch.toml
if [[ "$BP_EXECUTION_MODE" == "direct" ]]; then
    echo "Enabling direct execution mode..."
    
    cat <<EOF > "$venv_layer/bin/direct_exec"
#!/bin/sh
exec "\$@"
EOF
    chmod +x "$venv_layer/bin/direct_exec"
    
    if [[ -n "$SCRIPT_NAME" ]]; then
        echo "Setting default process 'scripts' to: direct_exec uv run $SCRIPT_NAME"
        cat <<EOF > "$CNB_LAYERS_DIR/launch.toml"
[[processes]]
type = "scripts"
command = ["$venv_layer/bin/direct_exec", "uv", "run", "$SCRIPT_NAME"]
default = true
EOF
    else
        echo "No script found. Setting default process 'scripts' to: direct_exec (ad-hoc)"
        cat <<EOF > "$CNB_LAYERS_DIR/launch.toml"
[[processes]]
type = "scripts"
command = ["$venv_layer/bin/direct_exec"]
default = true
EOF
    fi

else
    # Standard Mode
    if [[ -n "$SCRIPT_NAME" ]]; then
        echo "Setting default process 'scripts' to: uv run $SCRIPT_NAME"
        cat <<EOF > "$CNB_LAYERS_DIR/launch.toml"
[[processes]]
type = "scripts"
command = ["uv", "run", "$SCRIPT_NAME"]
default = true
EOF
    else
        echo "No scripts found. No default process set."
        echo "Please specify an args or command in your container configuration."
    fi
fi

echo "Build complete."
