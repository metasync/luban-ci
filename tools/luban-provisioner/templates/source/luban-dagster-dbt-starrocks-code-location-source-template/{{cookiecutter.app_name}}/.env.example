# Dagster Webserver Configuration
DAGSTER_WEBSERVER_HOST=0.0.0.0
DAGSTER_WEBSERVER_PORT=3000

# Dagster / dbt Target Configuration
# Determines which profile configuration is used in dbt_project/profiles.yml
# Valid options: development, sandbox, production
DBT_TARGET={{ cookiecutter.default_env }}
DBT_THREADS=4
DBT_PROJECT_DIR=./dbt_project
DBT_PROFILES_DIR=./dbt_project

# Generate `target/manifest.json` automatically if missing (used by Dagster dbt assets)
LUBAN_DBT_PREPARE_ON_LOAD=1

# Optional: Dagster partitioning configuration
DAGSTER_DAILY_PARTITIONS_START_DATE=2026-03-01

# Optional: Partition change propagator mode
# - sensor (default): trigger daily facts per-partition after upstream dbt partitions materialize
# - eager: rely on Dagster eager automation for dws daily models (latest partition behavior)
LUBAN_PARTITION_CHANGE_PROPAGATOR_MODE=sensor

# Optional: Propagator catch-up
# When set to a positive integer, the propagation sensors will scan upstream materializations
# from the last N days on first startup (when no cursor exists yet) and enqueue downstream
# runs for those partitions.
LUBAN_PARTITION_CHANGE_PROPAGATOR_CATCHUP_DAYS=0

# Optional: Observation schedule
# Cron for ODS/source observation checks.
LUBAN_OBSERVE_SOURCES_CRON=*/5 * * * *

# StarRocks Database Configuration
# These are required to connect Dagster and dbt to StarRocks
STARROCKS_HOST=localhost
STARROCKS_PORT=9030
STARROCKS_USER=root
STARROCKS_PASSWORD=
STARROCKS_USE_PURE=true
{% if cookiecutter.default_env == 'development' %}{% set sr_env = 'dev' %}{% elif cookiecutter.default_env == 'sandbox' %}{% set sr_env = 'snd' %}{% else %}{% set sr_env = 'prd' %}{% endif %}
STARROCKS_ODS_DB={{cookiecutter.package_name}}_ods_{{ sr_env }}
STARROCKS_DWD_DB={{cookiecutter.package_name}}_dwd_{{ sr_env }}
STARROCKS_DWS_DB={{cookiecutter.package_name}}_dws_{{ sr_env }}
STARROCKS_DB={{cookiecutter.package_name}}_dws_{{ sr_env }}

# Optional: Override schema/database names used for dbt models

# Optional: Override query timeouts
# STARROCKS_QUERY_TIMEOUT_SECONDS=3600
# STARROCKS_PLANNER_OPTIMIZE_TIMEOUT_MS=300000
